# Copy to terraform.tfvars and fill in the values CodeVine provides.
# Do NOT commit terraform.tfvars (it is gitignored).

# --- Your account ---
aws_region  = "us-east-1"
aws_profile = "my-codevine-gateway-admin" # an AWS CLI profile with admin in your account

# --- Assigned by CodeVine ---
customer                 = "acme"              # your assigned identifier
control_plane_account_id = "996904209118"      # CodeVine control plane account
control_plane_url        = "https://id.codevine.ai"

# registration_secret is sensitive — prefer the environment variable:
#   export TF_VAR_registration_secret='...'
# or put it in a gitignored secret.auto.tfvars file.

# --- Optional sizing (defaults shown) ---
# gateway_cpu    = 512
# gateway_memory = 1024
# desired_count  = 2
# min_count      = 1
# max_count      = 10

# --- Optional WAF ---
# enable_waf     = false
# waf_count_mode = true

# --- Optional hard data retention ---
# Auto-expire raw chat source data (S3 payloads + DynamoDB items) after N days.
# 0 (default) = retain forever. When set, AWS enforces deletion: S3 objects and
# their noncurrent versions expire, DynamoDB items expire via TTL (active sessions
# slide forward so they don't vanish mid-use), and log retention is capped to match.
# NOTE: DynamoDB PITR keeps up to 35 days of backups independent of this; disable
# PITR (modules/gateway/service.tf) for a strict guarantee under 35 days.
# source_data_retention_days = 90
